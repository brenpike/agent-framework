    },
    {
      "file": "plugin/agents/orchestrator.md",
      "pattern": "Write",
      "absent": true
    },
    {
      "file": "plugin/agents/orchestrator.md",
      "pattern": "Edit",
      "absent": true
    }
  ]
}
